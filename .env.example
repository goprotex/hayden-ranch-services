# Environment variables for Hayden Ranch Services
# Copy this to .env.local and fill in your values

# Mapbox (for satellite maps in fencing tool)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here
NEXT_PUBLIC_FENCING_MAP_STYLE=mapbox://styles/your-account/your-style-id

# Anthropic API key (for AI-powered receipt OCR parsing via Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase — for reliable cross-browser price & receipt sync
# These are auto-added to Vercel by the Supabase integration (prefix: Prices)
PRICES_URL=https://your-project.supabase.co
PRICES_SERVICE_ROLE_KEY=your_service_role_key_here
