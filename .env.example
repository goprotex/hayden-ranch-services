# Environment variables for Hayden Ranch Services
# Copy this to .env.local and fill in your values

# Mapbox (for satellite maps in fencing tool)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Anthropic API key (for AI-powered receipt OCR parsing via Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vercel KV (Redis) — for reliable cross-browser price & receipt sync
# Create a KV database at vercel.com/dashboard → Storage → Create Database → KV
# Then copy the credentials from the .env.local tab in the database settings.
KV_REST_API_URL=your_kv_rest_api_url_here
KV_REST_API_TOKEN=your_kv_rest_api_token_here
