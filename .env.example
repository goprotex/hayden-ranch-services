# Environment variables for Hayden Ranch Services
# Copy this to .env.local and fill in your values

# Mapbox (for satellite maps in fencing tool)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# OpenAI API key (for AI-powered receipt OCR parsing)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic API key (for AI-powered report parsing)
ANTHROPIC_API_KEY=your_anthropic_key_here
